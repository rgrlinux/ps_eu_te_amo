{% extends 'core/base.html' %}

{% block title %}Nova Mensagem{% endblock %}

{% block content %}
<div style="max-width: 800px; margin: 40px auto;">
    <div class="card">
        <h2>Mensagem para: {{ destinatario.nome }} 💌</h2>

        <form method="post" enctype="multipart/form-data">
            {% csrf_token %}

            {% for field in form %}
            <div class="form-group">
                <label>{{ field.label }}</label>
                {{ field }}
                {% if field.help_text %}
                    <div class="help-text">{{ field.help_text }}</div>
                {% endif %}
            </div>
            {% endfor %}

            <div class="form-group">
                <label>Fotos e imagens (opcional)</label>
                <input type="file" name="arquivos" multiple accept="image/*" class="form-control">
                <div class="help-text">Você pode enviar várias fotos</div>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%;">Salvar Mensagem</button>
        </form>
    </div>
</div>
{% endblock %}
